---
import BaseLayout from '../layouts/BaseLayout.astro';
import galleryContent from '../content/gallery.json';
import products from '../content/products.json';

const categories = galleryContent.categories;
const categoryLabelMap = new Map(categories.map((category) => [category.slug, category.label]));
const galleryItems = products.map((product) => ({
  ...product,
  displayImage: product.image,
}));
---

<BaseLayout title={`${galleryContent.title} - Jewels by Patty`} description={galleryContent.intro}>
  <section class="gallery-page">
    <div class="wrapper">
      <header class="gallery-page__intro">
        <p class="label label--center">{galleryContent.eyebrow}</p>
        <h1 class="section-title">{galleryContent.title}</h1>
        <div class="gold-rule"></div>
        <p class="section-sub">{galleryContent.intro}</p>
      </header>

      <ul class="gallery-page__categories" aria-label="Jewelry categories">
        {categories.map((category) => (
          <li>
            <button
              class:list={['gallery-filter', { 'gallery-filter--active': category.slug === 'all' }]}
              data-category={category.slug}
            >
              {category.label}
            </button>
          </li>
        ))}
      </ul>

      {
        galleryItems.length > 0 ? (
          <div class="gallery-grid gallery-page__grid">
            {galleryItems.map((item) => (
              <article class="gallery-item" data-category={item.category}>
                <img src={item.displayImage} alt={item.alt} loading="lazy" />
                <div class="gallery-item__shine"></div>
                <div class="gallery-page__meta">
                  <h2>{item.name}</h2>
                  <p>{categoryLabelMap.get(item.category) || item.category}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="gallery-page__empty">{galleryContent.emptyMessage}</p>
        )
      }

      <section class="gallery-page__cta">
        <p>{galleryContent.ctaText}</p>
        <a href={galleryContent.ctaHref} class="btn">{galleryContent.ctaButtonText}</a>
      </section>
    </div>
  </section>

<script>
  import '../assets/ts/gallery.ts';
</script>
</BaseLayout>
