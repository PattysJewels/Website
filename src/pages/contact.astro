---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../content/site.json';
import contactContent from '../content/contact.json';

const pageTitle = contactContent.title;
const pageIntro = contactContent.intro;

const displayPhone = contactContent.phone || site.phone || 'TBD';
const phoneDigits = displayPhone.replace(/\D/g, '');
const phoneHref = phoneDigits ? `tel:${phoneDigits}` : '';

const displayEmail = contactContent.email || '';
const emailHref = displayEmail ? `mailto:${displayEmail}` : '';

const { sections } = contactContent.form;
const placeholder = contactContent.form.selectPlaceholder;
---

<BaseLayout title={`${pageTitle} - Patty's Jewels`} description={pageIntro}>
  <section class="contact-page">
    <div class="wrapper">

      <header class="contact-page__intro">
        <p class="label label--center">{contactContent.eyebrow}</p>
        <h1 class="section-title">{pageTitle}</h1>
        <div class="gold-rule"></div>
        <p class="section-sub">{pageIntro}</p>
      </header>

      <div class="contact-methods">
        <div class="contact-card">
          <p class="contact-card__eyebrow">{contactContent.phoneCard.eyebrow}</p>
          {displayPhone !== 'TBD' ? (
            <>
              <p class="contact-card__value">{displayPhone}</p>
              <a class="btn contact-card__btn" href={phoneHref}>
                {contactContent.phoneCard.ctaText}
              </a>
              <p class="contact-card__copy">{contactContent.phoneCard.copy}</p>
            </>
          ) : (
            <p class="contact-card__note">{contactContent.phoneCard.fallbackNote}</p>
          )}
        </div>

        {displayEmail && (
          <div class="contact-card">
            <p class="contact-card__eyebrow">{contactContent.emailCard.eyebrow}</p>
            <p class="contact-card__value contact-card__value--email">{displayEmail}</p>
            <a class="btn contact-card__btn" href={emailHref}>
              {contactContent.emailCard.ctaText}
            </a>
          </div>
        )}
      </div>

      <div class="form-toggle-wrap">
        <button
          class="form-toggle"
          aria-expanded="false"
          aria-controls="contact-form-drawer"
        >
          {contactContent.formToggleText}
          <span class="form-toggle__icon" aria-hidden="true">↓</span>
        </button>
      </div>

      <div class="form-drawer" id="contact-form-drawer" aria-hidden="true">
        <form
          class="order-form"
          action="/api/contact"
          method="POST"
        >

          <fieldset class="order-form__section">
            <legend class="order-form__legend">{sections.contactInfo.legend}</legend>
            <div class="form-grid form-grid--double">
              <label class="form-field">
                <span>{sections.contactInfo.fullNameLabel}</span>
                <input type="text" name="full_name" autocomplete="name" required />
              </label>
              <label class="form-field">
                <span>{sections.contactInfo.emailLabel}</span>
                <input type="email" name="email" autocomplete="email" required />
              </label>
              <label class="form-field">
                <span>{sections.contactInfo.phoneLabel}</span>
                <input type="tel" name="phone_number" autocomplete="tel" />
              </label>
            </div>
          </fieldset>

          <fieldset class="order-form__section">
            <legend class="order-form__legend">{sections.message.legend}</legend>
            <div class="form-grid">
              <label class="form-field">
                <span>{sections.message.topicLabel}</span>
                <select name="topic" required>
                  <option value="">{placeholder}</option>
                  {sections.message.topicOptions.map((option) => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              </label>
              <label class="form-field form-field--full">
                <span>{sections.message.messageLabel}</span>
                <textarea name="message" rows="6" required></textarea>
              </label>
            </div>
          </fieldset>

          <button class="btn order-form__submit" type="submit">{contactContent.form.submitText}</button>
        </form>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  import '../assets/ts/contact-form.ts';
</script>
