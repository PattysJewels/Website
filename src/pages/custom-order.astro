---
import BaseLayout from '../layouts/BaseLayout.astro';
import content from '../content/custom-order.json';

const { eyebrow, title, intro, howItWorks, anchors, charts, form } = content;
const { sections } = form;
const placeholder = form.selectPlaceholder;
---

<BaseLayout title={`${title} - Patty's Jewels`} description={intro}>
  <section class="custom-order-page">
    <div class="wrapper">

      <header class="custom-order-page__intro">
        <p class="label label--center">{eyebrow}</p>
        <h1 class="section-title">{title}</h1>
        <div class="gold-rule"></div>
        <p class="section-sub">{intro}</p>
      </header>

      <div class="how-it-works">
        <h2 class="how-it-works__title">{howItWorks.title}</h2>
        <ol class="how-it-works__steps">
          {howItWorks.steps.map((step) => (
            <li class="how-it-works__step">
              <span class="how-it-works__number">{step.number}</span>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </div>

      <nav class="chart-anchors" aria-label="Jump to section">
        {anchors.map((anchor) => (
          <a href={anchor.href} class="chart-anchor">{anchor.label}</a>
        ))}
      </nav>

      <div class="chart-sections">
        {charts.map((chart) => (
          <section
            class:list={['chart-section', { 'chart-section--wide': chart.wide }]}
            id={chart.id}
          >
            {chart.wide ? (
              <div class="chart-section__wide-inner">
                <div class="chart-section__text">
                  <h2 class="chart-section__title">{chart.title}</h2>
                  <p class="chart-section__instruction">{chart.instruction}</p>
                </div>
                <img src={chart.image} alt={chart.title} loading="lazy" class="chart-section__img" />
              </div>
            ) : (
              <div class="chart-section__inner">
                <img src={chart.image} alt={chart.title} loading="lazy" class="chart-section__img" />
                <div class="chart-section__text">
                  <h2 class="chart-section__title">{chart.title}</h2>
                  <p class="chart-section__instruction">{chart.instruction}</p>
                </div>
              </div>
            )}
          </section>
        ))}
      </div>

      <div class="custom-order-page__form-wrap" id={form.id}>
        <h2 class="custom-order-page__form-heading">Ready? Fill out the form below.</h2>
        <p class="custom-order-page__form-note">{form.topNote}</p>

        <form
          class="order-form"
          action="/api/custom-order"
          method="POST"
        >

          <fieldset class="order-form__section">
            <legend class="order-form__legend">{sections.contactInfo.legend}</legend>
            <div class="form-grid form-grid--double">
              <label class="form-field">
                <span>{sections.contactInfo.fullNameLabel}</span>
                <input type="text" name="full_name" autocomplete="name" required />
              </label>
              <label class="form-field">
                <span>{sections.contactInfo.emailLabel}</span>
                <input type="email" name="email" autocomplete="email" required />
              </label>
              <label class="form-field">
                <span>{sections.contactInfo.phoneLabel}</span>
                <input type="tel" name="phone_number" autocomplete="tel" />
              </label>
            </div>
            <div class="form-choice">
              <p>{sections.contactInfo.preferredContactLabel}</p>
              <div class="choice-grid">
                {sections.contactInfo.preferredContactOptions.map((option, i) => (
                  <label>
                    <input
                      type="radio"
                      name="preferred_contact_method"
                      value={option}
                      required={i === 0}
                    />
                    {option}
                  </label>
                ))}
              </div>
            </div>
          </fieldset>

          <fieldset class="order-form__section">
            <legend class="order-form__legend">{sections.pieceDetails.legend}</legend>
            <div class="form-grid form-grid--double">
              <label class="form-field">
                <span>{sections.pieceDetails.pieceTypeLabel}</span>
                <select name="piece_type" required>
                  <option value="">{placeholder}</option>
                  {sections.pieceDetails.pieceTypeOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
              </label>
              <label class="form-field">
                <span>{sections.pieceDetails.quantityLabel}</span>
                <select name="quantity" required>
                  <option value="">{placeholder}</option>
                  {sections.pieceDetails.quantityOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
              </label>
            </div>
          </fieldset>

          <fieldset class="order-form__section">
            <legend class="order-form__legend">{sections.customization.legend}</legend>
            <div class="form-grid form-grid--double">

              <label class="form-field">
                <span>{sections.customization.earringHookLabel}</span>
                <select name="earring_hook_style">
                  <option value="">{placeholder}</option>
                  {sections.customization.earringHookOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
                <small class="form-field__hint">{sections.customization.earringHookHint}</small>
              </label>

              <label class="form-field">
                <span>{sections.customization.charmLabel}</span>
                <select name="charm_pendant">
                  <option value="">{placeholder}</option>
                  {sections.customization.charmOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
                <small class="form-field__hint">{sections.customization.charmHint}</small>
              </label>

              <label class="form-field">
                <span>{sections.customization.claspLabel}</span>
                <select name="necklace_clasp">
                  <option value="">{placeholder}</option>
                  {sections.customization.claspOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
                <small class="form-field__hint">{sections.customization.claspHint}</small>
              </label>

              <label class="form-field">
                <span>{sections.customization.necklaceLengthLabel}</span>
                <select name="necklace_length">
                  <option value="">{placeholder}</option>
                  {sections.customization.necklaceLengthOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
                <small class="form-field__hint">{sections.customization.necklaceLengthHint}</small>
              </label>

              <label class="form-field">
                <span>{sections.customization.braceletSizeLabel}</span>
                <select name="bracelet_size">
                  <option value="">{placeholder}</option>
                  {sections.customization.braceletSizeOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
              </label>

              <div class="form-field">
                <span class="form-field__label">{sections.customization.metalLabel}</span>
                <p class="form-field__note">{sections.customization.metalNote}</p>
                <select name="metal_finish">
                  <option value="">{placeholder}</option>
                  {sections.customization.metalOptions.map((o) => (
                    <option value={o}>{o}</option>
                  ))}
                </select>
              </div>

              <label class="form-field form-field--full">
                <span>{sections.customization.notesLabel}</span>
                <textarea
                  name="notes"
                  rows="5"
                  placeholder={sections.customization.notesPlaceholder}
                ></textarea>
              </label>

            </div>
          </fieldset>

          <div class="order-form__footer">
            <button class="btn" type="submit">{form.submitText}</button>
            <p class="order-form__submit-note">{form.submitNote}</p>
          </div>
        </form>
      </div>

    </div>
  </section>
</BaseLayout>
